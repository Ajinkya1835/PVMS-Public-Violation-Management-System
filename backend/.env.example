# Copy to .env and fill in your values
PORT=5000

# MongoDB — Option 1: local Docker (npm run db:up) — easiest
MONGO_URI=mongodb://localhost:27017/pvms

# MongoDB — Option 2: Atlas cloud (replace USER, PASSWORD, hosts)
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/pvms?retryWrites=true&w=majority

# JWT signing secret (use a long random string in production)
JWT_SECRET=change_me_to_a_secure_random_string
