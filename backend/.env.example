# Copy to .env and fill in your values
PORT=5000

# MongoDB — use Atlas connection string (standard mongodb:// avoids SRV DNS issues on Windows)
MONGO_URI=mongodb://USER:PASSWORD@host1:27017,host2:27017,host3:27017/pvms?ssl=true&replicaSet=YOUR_REPLICA&authSource=admin&retryWrites=true&w=majority

# JWT signing secret (use a long random string in production)
JWT_SECRET=change_me_to_a_secure_random_string
